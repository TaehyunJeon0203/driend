{
  "expo": {
    "name": "Driend",
    "slug": "driend",
    "version": "1.0.0",
    "scheme": "driend",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.driend.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "주행 경로를 기록하기 위해 위치 정보가 필요합니다.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "주행 중 화면을 보고 있지 않아도 경로 기록이 끊기지 않도록, 그리고 주행이 감지되면 알림으로 기록 시작을 제안하기 위해 앱을 사용하지 않는 동안에도 위치 정보를 확인합니다. 설정에서 언제든 끌 수 있습니다.",
        "NSCameraUsageDescription": "지역 사진을 촬영하기 위해 카메라 접근이 필요합니다.",
        "NSPhotoLibraryUsageDescription": "지역 사진을 업로드하기 위해 사진 라이브러리 접근이 필요합니다.",
        "NSLocalNetworkUsageDescription": "개발 서버(Metro)에 연결하기 위해 로컬 네트워크 접근이 필요합니다."
      }
    },
    "android": {
      "package": "com.driend.app",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-secure-store",
      [
        "@react-native-kakao/core",
        {
          "nativeAppKey": "83493d18b522a2aa69a658dc228f55ca"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "주행 중 화면을 보고 있지 않아도 경로 기록이 끊기지 않도록, 그리고 주행이 감지되면 알림으로 기록 시작을 제안하기 위해 앱을 사용하지 않는 동안에도 위치 정보를 확인합니다. 설정에서 언제든 끌 수 있습니다.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "지역 사진을 업로드하기 위해 사진 라이브러리 접근이 필요합니다."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#047857",
          "sounds": []
        }
      ],
      [
        "@mj-studio/react-native-naver-map",
        {
          "client_id": "wuodc80i7z"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ]
    ]
  }
}
